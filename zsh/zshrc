# set path for brew
[[ -e ~/.plugins/02-brew.sh ]] && source ~/.plugins/02-brew.sh

# setting for zsh
export DISABLE_MAGIC_FUNCTIONS=true

# History settings - share across sessions immediately
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY        # share history between all sessions in real-time
setopt HIST_IGNORE_DUPS     # don't record duplicate consecutive commands
setopt HIST_IGNORE_SPACE    # don't record commands starting with a space

# Zinit initialization
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
if [[ -d $ZINIT_HOME ]]; then
    source "${ZINIT_HOME}/zinit.zsh"

    # opencli completion
    fpath=(/Users/xdays/.zsh/completions $fpath)

    # Load plugins with turbo mode (deferred loading for faster startup)
    # zsh-autosuggestions
    # - Default highlight color (fg=8) can be invisible on some terminal themes.
    # - Load this immediately so suggestions work from the first prompt.
    : ${ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE:=fg=cyan}
    # NOTE: Don't use `${var:=(...)}` for arrays in zsh; it will create a scalar
    # like "(history completion)" and break strategy dispatch.
    if [[ -z ${ZSH_AUTOSUGGEST_STRATEGY+x} ]]; then
        typeset -ga ZSH_AUTOSUGGEST_STRATEGY
        ZSH_AUTOSUGGEST_STRATEGY=(history completion)
    fi
    zinit light zsh-users/zsh-autosuggestions

    # Other plugins can be deferred for faster startup.
    # Keep zsh-syntax-highlighting last (it must be sourced after other plugins).
    zinit wait lucid light-mode for \
        atinit"zicompinit; zicdreplay" \
        zsh-users/zsh-completions \
        zsh-users/zsh-syntax-highlighting

    # Load OMZ git library and plugin
    zinit wait lucid for \
        OMZL::git.zsh \
        OMZP::git

elif [[ -d $HOME/.oh-my-zsh ]]; then
    # Fallback to oh-my-zsh
    export ZSH=$HOME/.oh-my-zsh
    ZSH_THEME="robbyrussell"
    plugins=(zsh-autosuggestions macos git docker kubectl helm aws tmux gcloud terraform vault minikube)
    DISABLE_UPDATE_PROMPT=true
    SHOW_AWS_PROMPT=false
    CASE_SENSITIVE=true
    ZSH_DISABLE_COMPFIX=true
    source $ZSH/oh-my-zsh.sh
else
    export PS1='[\[\033[32m\]$(parse_git_branch)\[\033[00m\]\h:\W]\$ '
fi

# common plugins
if [[ -e ~/.plugins ]]; then
    for i in $(find ~/.plugins/ -type f -name "*.sh" | sort); do
        source $i
    done
fi

# extra plugins
if [[ -e ~/.extras ]]; then
    for i in $(find ~/.extras/ -type f | sort); do
        source $i
    done
fi

if uname -a | grep -q "Linux\|Darwin"; then
    goenv
fi

if [[ $(uname) == "Linux" ]] && [[ -z "$TMUX" ]]; then
    tmux
else
    echo
fi
